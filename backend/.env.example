# Backend configuration — copy to .env and fill in.

# MongoDB connection string and database name
MONGO_URL=mongodb://localhost:27017
DB_NAME=vzas_ai

# OpenRouter API key — powers chat replies and the Living Stories engine.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug used via OpenRouter (override to swap models without code changes).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# OpenAI API key — powers DALL-E 3 avatar generation (optional).
# If unset, avatar generation returns "not configured" and the app uses
# the preset avatar pool. Get one at https://platform.openai.com
OPENAI_API_KEY=
