# Backend configuration — copy to .env and fill in.

# MongoDB connection string and database name
MONGO_URL=mongodb://localhost:27017
DB_NAME=vzas_ai

# OpenRouter API key — powers chat replies and the Living Stories engine.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug used via OpenRouter for SFW chats (default).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Model slug used for chats with characters flagged nsfw=true.
# Claude/GPT-4 refuse explicit content; use an uncensored model here.
# Other good options: neversleep/noromaid-20b, sao10k/l3-lunaris-8b
OPENROUTER_NSFW_MODEL=gryphe/mythomax-l2-13b

# Replicate API token — powers character avatar generation.
# Get one at https://replicate.com/account/api-tokens. Pay-per-image (~$0.003-0.01).
REPLICATE_API_TOKEN=

# Replicate model slugs (env-configurable so you can swap any time).
# Default SFW: Flux Schnell — fast, cheap, general-purpose.
REPLICATE_MODEL=black-forest-labs/flux-schnell
# Default NSFW: SDXL Pony Diffusion v6 — the anime + NSFW standard.
REPLICATE_NSFW_MODEL=lucataco/sdxl:7762fd07cf82c948538e41f63f77d685e02b063e37e496e96eefd46c929f9bdc
