{
  "theme": "dark",
  "archetype": "5 (Luxury / Immersive with Neon accents)",
  "typography": {
    "font_family_primary": "Inter, SF Pro Display",
    "font_family_secondary": "Inter, SF Pro Display",
    "scales": {
      "h1": { "font_size": 28, "font_weight": "bold", "letter_spacing": -0.5, "line_height": 34 },
      "h2": { "font_size": 22, "font_weight": "600", "letter_spacing": -0.3, "line_height": 28 },
      "h3": { "font_size": 18, "font_weight": "500", "letter_spacing": -0.2, "line_height": 24 },
      "body": { "font_size": 16, "font_weight": "normal", "letter_spacing": 0, "line_height": 24 },
      "caption": { "font_size": 13, "font_weight": "normal", "letter_spacing": 0.2, "line_height": 18 },
      "button": { "font_size": 16, "font_weight": "600", "letter_spacing": 0.5, "line_height": 20, "text_transform": "none" }
    }
  },
  "colors": {
    "background": {
      "primary": "#0D0D1A",
      "secondary": "#1A1A2E",
      "card": "#1A1A2E",
      "bottom_sheet": "#1A1A2E"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#A0A0C0",
      "inverse": "#0D0D1A"
    },
    "brand": {
      "primary": "#7C3AED",
      "secondary": "#06B6D4"
    },
    "status": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444"
    },
    "border": {
      "default": "rgba(255, 255, 255, 0.1)",
      "focus": "#7C3AED"
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "2xl": 48
  },
  "border_radius": {
    "sm": 8,
    "md": 16,
    "lg": 24,
    "pill": 9999
  },
  "shadows": {
    "card": "0px 4px 12px rgba(0, 0, 0, 0.3)",
    "glow_primary": "0px 0px 16px rgba(124, 58, 237, 0.4)",
    "glow_secondary": "0px 0px 16px rgba(6, 182, 212, 0.4)"
  },
  "components": {
    "buttons": {
      "primary": {
        "style": "pill_shaped",
        "background": "linear-gradient(90deg, #7C3AED, #9D4CDD)",
        "text_color": "#FFFFFF",
        "border_radius": 9999,
        "padding": "16px 24px"
      },
      "secondary": {
        "style": "rounded_rectangle",
        "background": "transparent",
        "border": "1px solid rgba(255,255,255,0.2)",
        "text_color": "#FFFFFF",
        "border_radius": 16,
        "padding": "16px 24px"
      }
    },
    "cards": {
      "background": "#1A1A2E",
      "border_radius": 16,
      "padding": 16,
      "shadow": "0px 4px 12px rgba(0, 0, 0, 0.3)",
      "border": "1px solid rgba(255, 255, 255, 0.05)"
    },
    "navigation_bar": {
      "type": "bottom_tab",
      "style": "frosted_glass",
      "background": "rgba(26, 26, 46, 0.8)",
      "blur": "10px",
      "active_tint": "#7C3AED",
      "inactive_tint": "#A0A0C0"
    },
    "bottom_sheet": {
      "background": "#1A1A2E",
      "border_top_radius": 24,
      "indicator_color": "rgba(255,255,255,0.2)"
    },
    "inputs": {
      "background": "rgba(255, 255, 255, 0.05)",
      "border": "1px solid rgba(255, 255, 255, 0.1)",
      "border_radius": 12,
      "padding": "16px",
      "text_color": "#FFFFFF",
      "placeholder_color": "#A0A0C0"
    },
    "chat_bubbles": {
      "user": {
        "background": "#7C3AED",
        "text_color": "#FFFFFF",
        "border_radius": "20px 20px 4px 20px"
      },
      "character": {
        "background": "#1A1A2E",
        "border": "1px solid rgba(255, 255, 255, 0.1)",
        "text_color": "#FFFFFF",
        "border_radius": "20px 20px 20px 4px"
      }
    }
  },
  "animations": {
    "buttons": "Subtle scale down (0.95) on press",
    "avatars": "Slow continuous breathing or subtle float animation for character immersion",
    "navigation": "Smooth crossfade on tab switch",
    "bottom_sheet": "Spring physics for opening/closing"
  },
  "testing": {
    "required_attributes": ["data-testid"]
  },
